# ─── Worker Secrets (local development) ─────────────
# Copy this file to .dev.vars and fill in the values.
# These are loaded by `wrangler dev` automatically.
# In production, set these via: wrangler secret put <KEY> --env production

# Origin server URL (where Express is running)
ORIGIN_URL=http://localhost:3100

# Optional: bypass token for rate limiting (used by monitoring/CI)
# RATE_LIMIT_BYPASS_TOKEN=your-secret-token-here
